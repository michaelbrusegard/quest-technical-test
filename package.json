{
  "$schema": "https://json.schemastore.org/package",
  "name": "quest-technical-test",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "bunx vite build",
    "dev": "bunx vite",
    "fmt": "oxfmt --write src/**/*.ts src/**/*.tsx",
    "fmt:check": "oxfmt --check src/**/*.ts src/**/*.tsx",
    "fmt:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:rs:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -W clippy::all",
    "lint:rs:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --fix --allow-dirty -- -W clippy::all",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:rs": "cargo test --manifest-path src-tauri/Cargo.toml",
    "prepare": "lefthook install",
    "tauri": "tauri"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.58",
    "@ai-sdk/openai": "3.0.41",
    "@assistant-ui/react": "0.12.19",
    "@assistant-ui/react-markdown": "0.12.6",
    "@base-ui/react": "1.3.0",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource/cal-sans": "5.2.3",
    "@heroicons/react": "2.2.0",
    "@hugeicons/core-free-icons": "4.0.0",
    "@hugeicons/react": "1.1.6",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router": "1.167.4",
    "@tanstack/router-plugin": "1.166.10",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-http": "2.5.7",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-stronghold": "2.3.1",
    "ai": "6.0.116",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "remark-gfm": "4.0.1",
    "shadcn": "4.0.8",
    "sql.js": "1.14.1",
    "tailwind-merge": "3.5.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/solid-devtools": "0.8.0",
    "@tanstack/solid-router-devtools": "1.166.8",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.10",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "jsdom": "29.0.0",
    "lefthook": "2.1.4",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.17.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
