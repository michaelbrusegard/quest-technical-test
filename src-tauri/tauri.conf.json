{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quest-technical-test",
  "version": "0.2.0",
  "identifier": "com.michaelbrusegard.quest-technical-test",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "quest-technical-test",
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "center": true,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
